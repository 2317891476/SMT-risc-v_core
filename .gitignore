# Iverilog compilation outputs
*.out
*.vvp

# Waveform files
*.vcd
*.fst

# Log files
*.log

# Object files and executables
*.o
*.elf

# RISC-V test config files
*.cgf

# Build artifacts
*.map
*.dump
*.verilog

# Vivado / FPGA generated artifacts
/.Xil/
/build/
vivado*.jou
vivado*.log
webtalk*
fpga/bram_init/*.coe
fpga/**/*.cache/
fpga/**/*.gen/
fpga/**/*.hw/
fpga/**/*.ip_user_files/
fpga/**/*.runs/
fpga/**/*.sim/
fpga/**/*.srcs/
fpga/**/*.xpr
fpga/**/*.xsa

# Verilog hex files (generated from assembly)
*.hex
rom/inst.hex
rom/data.hex

# Generated assembly is ignored by default, but ROM tests are source files.
*.s
!rom/*.s
!rom/*.S

# Simulation/debug outputs
comp_test/out_iverilog/
comp_test/ghostbug*.txt

# RISCOF work directories
verification/riscof/dut/
verification/riscof/references/
verification/riscof/riscof_work/
verification/riscof/sail_cSim/
**/__pycache__/

# Downloaded test suites (auto-downloaded)
verification/riscv-arch-test/
verification/riscv-tests/

# Test run outputs
verification/riscv_test_runs/
verification/adapter/

# Downloaded zip files
*.zip

# Backup files
*.bak
*~

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db
./verilator/